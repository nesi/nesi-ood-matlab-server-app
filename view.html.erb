<form action="/rnode/<%= host %>/<%= port %>/matlab?mwi-auth-token=<%= password %>" method="post" target="_blank">
  <input type="hidden" name="mwi-auth-token" value="<%= password %>"/>
  <button class="btn btn-primary" style="background-color: rgb(224 94 27);border-color: rgb(244 114 47);" type="submit">
    <i class="fa-solid fa-mound"></i> Connect to MATLAB Server
  </button>
</form>
