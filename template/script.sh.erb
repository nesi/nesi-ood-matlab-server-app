#!/bin/bash

# Benchmark info
echo "TIMING - Starting main script at: $(date)"

export SESSION_DIR="${PWD}"

# Set working directory to home directory
cd "${HOME}"

# TODO: NeSI/zen3 was not loaded, look into it
echo "list modules:"
ml
echo "load NeSI/zen3"
ml NeSI/zen3
echo "list modules:"
ml

echo "module purge"
module purge

# load matlab Server
echo "module load"
module load <%= context.mver %>

export MLM_LICENSE_FILE=<%= context.mlic %>

# load 
module load matlab-proxy/0.27.1-foss-2023a

# matlabServer doesn't inherit "ulimit -s" from system config /etc/security/limits.d/custom.conf
# Therefore, we are setting it here
ulimit -s unlimited

#
# Start matlab Server
#

TMPDIR="$(mktemp -d)"

# Output debug info
module list

# Launch the matlab Server
echo "Starting up matlab..."
set -x
#matlab-proxy-app
env MWI_BASE_URL="/node/${host}/${PORT_CFG}/matlab" matlab-proxy-app